TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Path to OAuth client secrets JSON (Web Application type)
GOOGLE_CLIENT_SECRETS_PATH=credentials/client_secrets_web.json

# OAuth callback settings (multi-user mode)
OAUTH_REDIRECT_URI=https://yourdomain.com/oauth/callback
OAUTH_SERVER_PORT=8080

# Database path
DATABASE_PATH=data/bot.db

# Your local timezone (IANA format)
TIMEZONE=Asia/Tashkent

# Admin Telegram ID (gets access to /list_users and /delete_user)
ADMIN_TELEGRAM_ID=your_telegram_id_here
